# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=Kosh API
LOG_LEVEL=INFO
ENVIRONMENT=development            # development | staging | production

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS_STR=http://localhost:3000,http://localhost:3001

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/kosh

# ── JWT / Auth ────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-use-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_PROVIDER=mock                  # mock | twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=kosh-invoices
S3_PREFIX=invoices

# ── Gemini ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── WhatsApp Cloud API ────────────────────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
